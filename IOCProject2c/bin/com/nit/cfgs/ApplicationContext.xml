<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">
           <bean id="comp" class="com.nit.sbeans.Company">
           <property name="dept1" ref="dept"></property>
           <property name="dept2" ref="dept"></property>
           <property name="dept3" ref="dept"></property>
           </bean>
           <bean id="dept" class="com.nit.sbeans.Department">
           <property name="deptId" value="201"></property>
           <property name="deptName" value="ECE"></property>
           </bean>
           </beans>